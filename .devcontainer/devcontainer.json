{
  "name": "PHP 8.4 Full Stack",
  "dockerComposeFile": "docker-compose.yml",
  "service": "php-app",
  "workspaceFolder": "/var/www/html",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "forwardPorts": [3000, 8080],
  "portsAttributes": {
    "3000": { "label": "La mia App (PHP)" },
    "8080": { "label": "phpMyAdmin" }
  },
  "postCreateCommand": "git config --global --add safe.directory /var/www/html && rm -f .git/hooks/pre-push",
  "postStartCommand": "sh .devcontainer/init-db.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "xdebug.php-debug",
        "bmewburn.vscode-intelephense-client"
      ]
    }
  }
}